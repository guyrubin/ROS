# OS / editor noise
.DS_Store
Thumbs.db
*:Zone.Identifier

# Obsidian local workspace state
.obsidian/workspace*
.obsidian/cache/
.obsidian/plugins/*/data.json
.obsidian/graph.json

# Python / build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Node / frontend artifacts
node_modules/
.npm/
.next/
out/
coverage/

# Local env / secrets
.env
.env.*
!.env.example
*.local
secrets.*
*.key
*.pem

# Semi-sensitive credential store (env-style key files) — NEVER commit values.
# Only README.md (the policy + non-secret registry) is tracked.
# Money/financial secrets NEVER go here → GCP Secret Manager.
/00_System/secrets/*
!/00_System/secrets/README.md

# Logs / temp
*.log
*.tmp
*.temp
*.out
.firebase/
.cache/
tmp/

# Runtime scratch & local agent config (not ROS knowledge)
.workspace/
.claude/settings.local.json

# Nested Arbor product clone (separate git remote: guyrubin/PPPPtherapy- → Arbor).
# Pending consolidation into PAI/arbor/ once the live sessions using it close.
/PPPPtherapy-/
# Nested-Arbor git worktrees parked at ROS root (build/council/dark/greenmain/
# mktdeploy/rel-*/w*) — owned by the nested Arbor repo, not ROS. Ignore the noise.
/.arbor-*/
# PAI/arbor/ is reserved as the single canonical Arbor clone home (its own remote).
/PAI/arbor/
# One-off helper script tied to the live .workspace session
/commit-logo.bat
