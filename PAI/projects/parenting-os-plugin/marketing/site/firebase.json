{
  "hosting": {
    "site": "arbor-marketing-il",
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": ["firebase.json", "**/.*"],
    "headers": [
      { "source": "**/*.@(html)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=300" }] }
    ]
  }
}
