{
  "name": "ros-interface-v4",
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen-state": "node ../guy-command-center/gen-state.mjs && node ../guy-command-center/gen-backlogs.mjs",
    "stage-data": "npm run gen-state && node scripts/stage-data.mjs",
